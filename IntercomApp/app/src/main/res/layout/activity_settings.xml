<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 伺服器 IP -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="伺服器 IP"
            android:textSize="14sp"
            android:textColor="#607D8B"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etServerIp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="192.168.100.163"
            android:inputType="text"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:layout_marginBottom="24dp" />

        <!-- 分機選擇 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="分機號碼"
            android:textSize="14sp"
            android:textColor="#607D8B"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerExtension"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp" />

        <!-- 密碼 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="密碼"
            android:textSize="14sp"
            android:textColor="#607D8B"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="password101"
            android:inputType="textPassword"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:layout_marginBottom="48dp" />

        <!-- 儲存按鈕 -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="儲存並重新連線"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <!-- 說明文字 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="提示：選擇分機後會自動填入預設密碼\n每支手機選不同分機（101-108）"
            android:textSize="12sp"
            android:textColor="#90A4AE"
            android:layout_marginTop="16dp" />

        <!-- ── 更新區塊 ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="16dp" />

        <!-- 版本資訊 + 檢查更新按鈕 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvCurrentVersion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="目前版本：載入中..."
                android:textSize="13sp"
                android:textColor="#546E7A" />

            <Button
                android:id="@+id/btnCheckUpdate"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="檢查更新"
                android:textSize="13sp"
                android:backgroundTint="#43A047"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp" />
        </LinearLayout>

        <!-- 下載進度條（隱藏，下載時顯示） -->
        <ProgressBar
            android:id="@+id/pbDownload"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:max="100"
            android:layout_marginBottom="4dp" />

        <!-- 更新狀態文字（隱藏，操作時顯示） -->
        <TextView
            android:id="@+id/tvUpdateStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="#78909C"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>

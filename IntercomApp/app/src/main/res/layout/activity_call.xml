<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- MJPEG 攝像頭畫面 -->
    <com.intercom.app.MjpegView
        android:id="@+id/mjpegView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 頂部狀態欄 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#99000000"
        android:padding="16dp"
        android:layout_alignParentTop="true">

        <!-- Row 1: 通話狀態 + 計時 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="通話中"
                android:textSize="18sp"
                android:textColor="#4CAF50"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="18sp"
                android:textColor="#FFFFFF" />

        </LinearLayout>

        <!-- Row 2: RTP debug 封包計數（小字） -->
        <TextView
            android:id="@+id/tvDebugStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="10sp"
            android:textColor="#80FFFFFF"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- 底部控制按鈕 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#99000000"
        android:padding="24dp"
        android:gravity="center"
        android:layout_alignParentBottom="true">

        <!-- 開門 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <Button
                android:id="@+id/btnUnlock"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:text=""
                android:backgroundTint="#FF9800"
                android:drawableTop="@android:drawable/ic_menu_send"
                android:elevation="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="開門"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- 掛斷 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <Button
                android:id="@+id/btnHangup"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:text=""
                android:backgroundTint="#F44336"
                android:drawableTop="@android:drawable/ic_menu_close_clear_cancel"
                android:elevation="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="掛斷"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
